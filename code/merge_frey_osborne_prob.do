label variable prob_computer "Computerization probability (Frey & Osborne 2017)"
save `crosswalk'

* -----------------------------------------------------------------------
* 3. Open the main data
* -----------------------------------------------------------------------
use "`ipums_file'", clear

* -----------------------------------------------------------------------
* 4. Delete observations OCCSOC == 0 
*    In IPUMS, 0 = no professional knowledge / not applicable.
* -----------------------------------------------------------------------
capture confirm string variable occsoc
if _rc != 0 {
    * Numeric ise
    drop if occsoc == 0
    tostring occsoc, replace
}
else {
    * String ise
    drop if occsoc == "0" | strtrim(occsoc) == "0" | occsoc == ""
}

display "occsoc==0 silindi. Kalan gözlem: " _N

* -----------------------------------------------------------------------
* 5. Clean OCCSOC
* -----------------------------------------------------------------------
replace occsoc = strtrim(occsoc)
replace occsoc = subinstr(occsoc, "-", "", .)

* If the leading zero is dropped, complete it to 6 digits (numeric codes only).
gen double _tmp = real(occsoc)
replace occsoc = string(_tmp, "%06.0f") if _tmp != .
drop _tmp

rename occsoc occsoc_raw

* -----------------------------------------------------------------------
* 6. MERGE
* -----------------------------------------------------------------------
merge m:1 occsoc_raw using `crosswalk', ///
    keep(master match)                   ///
    keepusing(prob_computer)             ///
    nogenerate

rename occsoc_raw occsoc

* -----------------------------------------------------------------------
* 7. RISK CATEGORY
*    IMPORTANT: In Stata, missing (.) is considered greater than all other numbers.
*   Without the `prob_computer != .` condition, missing entries are at high risk!
* -----------------------------------------------------------------------
gen risk_category = .
replace risk_category = 1 if prob_computer <  0.30 & prob_computer != .
replace risk_category = 2 if prob_computer >= 0.30 & prob_computer <  0.70
replace risk_category = 3 if prob_computer >= 0.70 & prob_computer != .

label define risk_lbl 1 "Low Risk (<0.30)"   ///
                      2 "Medium Risk (0.30-0.70)" ///
                      3 "High Risk (>0.70)"
label values risk_category risk_lbl
label variable prob_computer "Computerization probability (Frey & Osborne 2017)"
label variable risk_category "Risk category (Frey & Osborne 2017)"

* -----------------------------------------------------------------------
* 8. SAVE AND CONTROL
* -----------------------------------------------------------------------
save "`output_file'", replace

display _newline "=== Sonuç ==="
tab risk_category, missing
